generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model School {
  id        String   @id @default(uuid())
  name      String
  prefix    String   @unique
  createdAt DateTime @default(now())
  users     User[]
  rooms     Room[]
}

model User {
  id           String   @id
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id])
  role         Role     @default(STUDENT)
  displayName  String
  passwordHash String
  createdAt    DateTime @default(now())

  sessions       Session[]
  createdRooms   Room[]                       @relation("TeacherRooms")
  enrollments    Enrollment[]
  boardPosts     BoardPost[]
  studentNotes   StudentNote[]
  noteImages     StudentNoteImage[]
  surveyResponses SurveyResponse[]
  checkResponses UnderstandingCheckResponse[]
  notifications  Notification[]
}

enum Role {
  SERVER_ADMIN
  SCHOOL_ADMIN
  TEACHER
  STUDENT
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Room {
  id          String    @id
  name        String
  schoolId    String
  school      School    @relation(fields: [schoolId], references: [id])
  teacherId   String
  teacher     User      @relation("TeacherRooms", fields: [teacherId], references: [id])
  createdAt   DateTime  @default(now())
  endedAt     DateTime?
  notes       String    @default("")
  transcript  String    @default("")
  summary     String    @default("")

  reactions          Reaction[]
  surveys            Survey[]
  enrollments        Enrollment[]
  boardPosts         BoardPost[]
  studentNotes       StudentNote[]
  noteImages         StudentNoteImage[]
  understandingCheck UnderstandingCheck?
}

model Enrollment {
  id       String   @id @default(uuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roomId   String
  room     Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  joinedAt DateTime @default(now())

  @@unique([userId, roomId])
}

model Reaction {
  id        String   @id @default(uuid())
  type      String
  timestamp DateTime @default(now())
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

model Survey {
  id        String         @id @default(uuid())
  question  String
  isOpen    Boolean        @default(true)
  createdAt DateTime       @default(now())
  roomId    String
  room      Room           @relation(fields: [roomId], references: [id], onDelete: Cascade)
  options   SurveyOption[]
  responses SurveyResponse[]
}

model SurveyOption {
  id       String @id @default(uuid())
  text     String
  votes    Int    @default(0)
  surveyId String
  survey   Survey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  responses SurveyResponse[]
}

model SurveyResponse {
  id         String       @id @default(uuid())
  surveyId   String
  survey     Survey       @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  optionId   String
  option     SurveyOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  userId     String
  user       User         @relation(fields: [userId], references: [id])
  answeredAt DateTime     @default(now())

  @@unique([surveyId, userId])
}

model BoardPost {
  id        String   @id @default(uuid())
  content   String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model StudentNote {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  body      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, roomId])
}

model StudentNoteImage {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  fileName  String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())

}

model UnderstandingCheck {
  id          String    @id @default(uuid())
  roomId      String    @unique
  room        Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  scheduledAt DateTime
  notifiedAt  DateTime?
  tallyAt     DateTime?
  talliedAt   DateTime?
  resultBody  String    @default("") // 集計結果テキスト（スコア内訳 + AI 要約）
  responses   UnderstandingCheckResponse[]
}

model UnderstandingCheckResponse {
  id         String             @id @default(uuid())
  checkId    String
  check      UnderstandingCheck @relation(fields: [checkId], references: [id], onDelete: Cascade)
  userId     String
  user       User               @relation(fields: [userId], references: [id])
  score      Int
  comment    String             @default("")
  answeredAt DateTime           @default(now())

  @@unique([checkId, userId])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
}

enum NotificationType {
  UNDERSTANDING_CHECK
  UNDERSTANDING_RESULT
}
