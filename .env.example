# ──────────────────────────────────────────────
# Re:a Class — 環境変数サンプル
# cp .env.example .env してから各値を書き換えてください
# ──────────────────────────────────────────────

# PostgreSQL 接続 URL
# ローカル Docker 環境では "db" がサービス名なのでそのまま使用可
DATABASE_URL="postgresql://reaclass:reaclass_pass@db:5432/reaclass"

# セッション Cookie の署名シークレット
# openssl rand -hex 32 などで生成したランダムな文字列を入力
SESSION_SECRET="change-this-to-a-random-secret"

# cron エンドポイント (/api/cron/*) の認証キー
# curl -H "x-cron-secret: <この値>" で叩く
CRON_SECRET="change-this-to-a-random-secret"

# 手書きメモ画像などのアップロード保存先
# Docker Compose 環境では /app/uploads が named volume に保存されます
UPLOAD_DIR="/app/uploads"

# サーバー管理者の初期アカウント（初回起動時に自動作成）
# 起動後にパスワードを変更することを推奨
SERVER_ADMIN_ID="A00000001"
SERVER_ADMIN_PASS="change-this-password"
SERVER_ADMIN_NAME="システム管理者"

# Groq API キー（音声書き起こし・AI 要約・理解度集計に使用）
# 無料で取得可能 → https://console.groq.com
# 未設定の場合は AI 機能が無効になるだけでアプリ本体は動作します
GROQ_API_KEY=""
