DATABASE_URL="postgresql://reaclass:reaclass_pass@localhost:5432/reaclass"

# セッション署名用シークレット（ランダムな長い文字列）
SESSION_SECRET="change-this-to-a-random-secret"

# cron API の認証シークレット
CRON_SECRET="change-this-to-a-random-secret"

# サーバー管理者アカウント（初回起動時に自動作成）
SERVER_ADMIN_ID="A00000001"
SERVER_ADMIN_PASS="change-this-password"
SERVER_ADMIN_NAME="システム管理者"

# OpenAI API キー（任意・なければ AI 機能は無効）
OPENAI_API_KEY=""
